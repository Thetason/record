# Application
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
NEXT_PUBLIC_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@host:5432/record
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/record
POSTGRES_URL=postgresql://user:password@host:5432/record
POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/record

# OCR
ENABLE_OCR=true
ALLOW_MOCK_OCR=false
GOOGLE_VISION_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./google-vision-key.json
OCR_DEBUG=false

# Multi-review capture (Claude vision) — one scroll-capture → many reviews.
# Without a key, dev falls back to mock reviews; production returns a 503.
ANTHROPIC_API_KEY=
# Optional: cheaper model for bulk OCR (e.g. claude-haiku-4-5). Defaults to claude-opus-4-8.
ANTHROPIC_VISION_MODEL=

# Payments
NEXT_PUBLIC_LEMONSQUEEZY_PREMIUM_CHECKOUT_URL=https://record.lemonsqueezy.com/buy/ca2785bc-3695-42a6-8da0-d7b8732dda45?media=0&desc=0
NEXT_PUBLIC_LEMONSQUEEZY_PREMIUM_YEARLY_CHECKOUT_URL=
NEXT_PUBLIC_LEMONSQUEEZY_PRO_CHECKOUT_URL=https://record.lemonsqueezy.com/buy/8fe70d24-78d7-41e8-ad40-86f7afa1e71b?media=0&desc=0
NEXT_PUBLIC_LEMONSQUEEZY_PRO_YEARLY_CHECKOUT_URL=
LEMONSQUEEZY_PREMIUM_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PREMIUM_YEARLY_VARIANT_ID=
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_SIGNING_SECRET=
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_PREMIUM_PRODUCT_ID=
POLAR_BUSINESS_PRODUCT_ID=

# Email
ENABLE_EMAIL=false
RESEND_API_KEY=
SENDGRID_API_KEY=

# Diagnostics
HEALTHCHECK_TOKEN=replace-with-healthcheck-token

# Local demo seeding
DEMO_SEED_CONFIRM=YES
